{
  "cleanupPeriodDays": 60,
  "permissions": {
    "allow": [
      "Bash(echo:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(cargo:*)",
      "Read(**)",
      "Edit(~/projects/**)",
      "WebFetch(domain:*)",
      "Bash(npx create-expo-app:*)",
      "Bash(mkdir:*)",
      "Bash(start /min npm run db:studio)",
      "Bash(rmdir:*)",
      "Bash(npx tsc:*)",
      "Bash(find:*)",
      "Bash(powershell:*)",
      "Bash(npx eslint:*)",
      "WebSearch",
      "Bash(npx playwright:*)",
      "Bash(timeout 30 npx playwright test --headed --project=chromium e2e/dashboard-gamification.spec.ts)",
      "Bash(npx next build:*)",
      "Bash(curl:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Read(//**)",
      "Bash(node:*)",
      "Bash(npx tsx:*)",
      "Bash(timeout 10s npm test src/app/api/user-profiles/__tests__/user-profiles.test.ts)",
      "Bash(npx jest:*)",
      "Bash(npx storybook:*)",
      "Bash(grep:*)",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__onboarding",
      "mcp__serena__list_dir",
      "mcp__serena__find_file",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_symbol",
      "mcp__serena__write_memory",
      "mcp__serena__search_for_pattern",
      "mcp__ide__getDiagnostics",
      "mcp__serena__read_memory",
      "Bash(timeout 30s npm run test:e2e -- --grep \"should display dashboard\")",
      "Bash(test:*)",
      "Bash(chmod:*)",
      "Bash(./test-notification.sh:*)",
      "Bash(cat:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": []
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/notification-handler.sh"
          },
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/advanced-notification-handler.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/docs-validation-hook.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Update|mcp__serena__replace_symbol_body|mcp__serena__insert_.*_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/docs-validation-hook.sh"
          },
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/rules-validation.sh"
          }
        ]
      }
    ]
  }
}
