          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/notification-handler.sh"
          },
          {
            "type": "command",
            "command": "/Users/doi-ryoto/Desktop/Programming/routine_record/.claude/advanced-notification-handler.sh"
